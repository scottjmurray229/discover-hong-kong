---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import jeniceImg from '../../images/jenice-murray.jpg';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'About', url: '/about/' },
  { name: 'Jenice', url: '/about/jenice/' },
];

const schemaData = {
  name: 'Jenice Murray',
  image: '/images/jenice-murray.jpg',
  bio: 'Cultural guide and food expert who brings an Asian perspective and deep travel experience to Discovering Hong Kong.',
  url: 'https://discoveringhongkong.info/about/jenice/',
  knowsAbout: [
    'Hong Kong food culture',
    'Dim sum traditions',
    'Hong Kong festivals',
    'Local customs and etiquette',
    'Cantonese dining culture',
    'Night markets',
    'Temple culture',
  ],
  sameAs: [
    'https://www.youtube.com/@DiscoveringHongKong',
    'https://www.facebook.com/DiscoveringHongKong',
    'https://www.instagram.com/discovering.hongkong',
  ],
};

const blogPosts = [
  { slug: 'dim-sum-etiquette-guide', title: 'Dim Sum Etiquette: How to Order Like a Local in a Hong Kong Teahouse' },
  { slug: 'hong-kong-night-markets', title: 'Temple Street Night Market: What to Buy, Eat, and Skip' },
];

const destinations = [
  { slug: 'mong-kok', title: 'Mong Kok' },
  { slug: 'jordan', title: 'Jordan' },
  { slug: 'tsim-sha-tsui', title: 'Tsim Sha Tsui' },
  { slug: 'tai-o', title: 'Tai O' },
  { slug: 'stanley', title: 'Stanley' },
  { slug: 'wan-chai', title: 'Wan Chai' },
];

const coverageAreas = [
  { icon: '🫖', title: 'Dim Sum & Yum Cha', desc: 'The unwritten rules of ordering in a Hong Kong teahouse — what to ask for, how the trolley system works, what locals order versus what tourists get steered toward.' },
  { icon: '🍜', title: 'Food & Cuisine', desc: 'Wonton noodles, roast goose, char siu, egg tarts, pineapple buns, and the Cantonese culinary tradition that makes Hong Kong one of the world\'s great food cities.' },
  { icon: '🏮', title: 'Festivals & Celebrations', desc: 'When to go, what to expect, and how locals celebrate — from the Mid-Autumn Festival in Victoria Park to Chinese New Year fireworks over the harbour.' },
  { icon: '🗣️', title: 'Culture & Etiquette', desc: 'Key Cantonese phrases, when to use them, how to navigate dai pai dong culture, tipping norms, and the things that make Hong Kong locals smile versus cringe.' },
];
---

<BaseLayout
  title="Jenice Murray — Cultural Guide | Discovering Hong Kong"
  description="Meet Jenice Murray — cultural guide and food expert behind Discovering Hong Kong. Deep knowledge of dim sum culture, Hong Kong festivals, and Cantonese dining traditions."
  pageType="author"
  schemaData={schemaData}
  breadcrumbs={breadcrumbs}
>

<!-- HERO -->
<section class="author-hero">
  <video class="author-hero-video" autoplay muted loop playsinline preload="metadata">
    <source src="/videos/pillar/about-jenice-hero.mp4" type="video/mp4" />
  </video>
  <div class="author-hero-gradient-overlay"></div>
  <div class="hero-grid"></div>
  <div class="author-hero-inner">
    <Breadcrumb items={breadcrumbs} />
    <div class="hero-eyebrow">Meet the Local Expert</div>
    <div class="author-avatar-wrap">
      <Image src={jeniceImg} alt="Jenice Murray — Cultural Guide" class="author-avatar-large" width={120} height={120} format="webp" loading="eager" />
    </div>
    <h1>Jenice Murray</h1>
    <p class="hero-role">Cultural Guide & Food Expert</p>
    <p class="hero-location">The eye for what matters</p>
    <div class="hero-stats">
      <div class="hero-stat"><div class="hero-stat-num">10+</div><div class="hero-stat-label">HK trips together</div></div>
      <div class="hero-stat"><div class="hero-stat-num">Dim Sum</div><div class="hero-stat-label">Her specialty</div></div>
      <div class="hero-stat"><div class="hero-stat-num">Local</div><div class="hero-stat-label">Perspective always</div></div>
    </div>
  </div>
</section>

<!-- BIO -->
<section class="bio-section">
  <div class="bio-inner">
    <div class="section-eyebrow">About Jenice</div>
    <h2 class="section-title">The Eye for What Guidebooks Miss</h2>
    <div class="bio-content">
      <p>Hong Kong is one of the world's most layered cities — and the difference between a tourist experience and a local one can be as small as knowing which floor of a building to get off on, or which teahouse starts dim sum service at 6am. That's the difference Jenice brings to every trip.</p>
      <p>Where Scott researches the logistics, Jenice instinctively reads the room. She knows when a restaurant's clientele signals that the food is authentic versus tourist-oriented. She picks up on the cultural context — why the older gentleman at the next table is loudly slurping his soup (it's a compliment), why the teahouse doesn't have an English menu, and why that's actually a good sign.</p>
      <p>Growing up with an appreciation for Asian food culture and family traditions, Jenice brings a perspective to Hong Kong travel that most Western travel writers simply don't have. The instinct for which dai pai dong to trust. The comfort with pointing at something on someone else's plate and asking for the same. <strong>The understanding that great food in Hong Kong rarely announces itself.</strong></p>
      <p>She has navigated Temple Street Night Market without getting overcharged, found the egg tart shops that don't have queues around the block, and spotted the roast goose shops where locals queue even when tourists don't know they exist.</p>
      <p><strong>Scott has the maps and the logistics. Jenice has the taste and the instinct.</strong> Together, that's what makes the recommendations on this site worth trusting.</p>
    </div>
  </div>
</section>

<!-- CREDENTIALS -->
<section class="credentials-section">
  <div class="credentials-inner">
    <div class="section-eyebrow">Credentials</div>
    <h2 class="section-title">Why You Can Trust Jenice's Perspective</h2>
    <ul class="credential-list">
      <li><strong>Cultural reading</strong> that picks out authentic local spots from tourist traps at a glance</li>
      <li><strong>Dim sum expertise</strong> — knows the ordering system, the trolley etiquette, and what to ask for that isn't on the English menu</li>
      <li><strong>Festival knowledge</strong> — experienced Mid-Autumn, Chinese New Year, and Hungry Ghost Festival in Hong Kong</li>
      <li><strong>Food instinct</strong> — roast goose, wonton noodles, char siu, pineapple buns, egg tarts, and the street food that locals actually eat</li>
      <li><strong>Eye for authenticity</strong> — if the locals are eating there, she'll notice. If it's tourist bait, she'll say so.</li>
      <li><strong>Cultural etiquette</strong> — tipping norms, how to use chopsticks without embarrassing yourself, and when "M goi" versus "Do je" is correct</li>
    </ul>
  </div>
</section>

<!-- WHAT JENICE COVERS -->
<section class="coverage-section">
  <div class="coverage-inner">
    <div class="section-eyebrow">Content Areas</div>
    <h2 class="section-title">What Jenice Covers</h2>
    <div class="coverage-grid">
      {coverageAreas.map((area) => (
        <div class="coverage-card reveal">
          <div class="coverage-icon">{area.icon}</div>
          <div class="coverage-title">{area.title}</div>
          <p class="coverage-desc">{area.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CONTENT BY JENICE -->
<section class="content-section">
  <div class="content-inner">
    <div class="section-eyebrow">Content by Jenice</div>
    <h2 class="section-title">Articles & Guides</h2>

    <h3 class="content-subhead">Blog Posts</h3>
    <div class="content-grid">
      {blogPosts.map((post) => (
        <a href={`/blog/${post.slug}/`} class="content-card reveal">
          <div class="content-card-type">Blog</div>
          <div class="content-card-title">{post.title}</div>
        </a>
      ))}
    </div>

    <h3 class="content-subhead">Destination Guides (Cultural Sections)</h3>
    <div class="content-grid content-grid--destinations">
      {destinations.map((dest) => (
        <a href={`/destinations/${dest.slug}/`} class="content-card content-card--dest reveal">
          <div class="content-card-type">Destination</div>
          <div class="content-card-title">{dest.title}</div>
        </a>
      ))}
    </div>

    <div class="content-all-link">
      <a href="/destinations/">Browse all destination guides &rarr;</a>
    </div>
  </div>
</section>

<!-- EMAIL CAPTURE -->
<section class="email-section">
  <div class="email-section-inner">
    <EmailCapture
      leadMagnet="Get Jenice's Hong Kong Food & Culture Guide"
      description="Insider tips from someone who knows the difference between what tourists eat and what locals order &mdash; plus the cultural context that makes it all make sense."
      bullets={[
        'Dim sum ordering guide with Cantonese names',
        'Key Cantonese phrases for food and travel',
        'Festival calendar with insider tips',
        'Cultural etiquette guide for Hong Kong',
      ]}
      guideTag="author-jenice"
    />
  </div>
</section>

<!-- BACK LINK -->
<section class="back-section">
  <div class="back-inner">
    <a href="/about/" class="back-link">&larr; Back to About Us</a>
  </div>
</section>

</BaseLayout>

<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const ro = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => ro.observe(el));
  } else {
    document.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
  }
</script>

<style>
  /* ═══════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════ */
  .author-hero {
    padding: 140px 24px 80px;
    position: relative;
    overflow: hidden;
    text-align: center;
    background: linear-gradient(165deg, #141C26 0%, #3D2008 30%, #78350F 55%, #3D2008 75%, #141C26 100%);
  }
  .author-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .author-hero-gradient-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.15) 40%, rgba(0,0,0,0.55) 100%);
    z-index: 0;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(255,255,255,0.012) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.012) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .author-hero-inner {
    max-width: 660px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }
  .author-hero-inner :global(.breadcrumb) {
    margin-bottom: var(--space-8);
  }
  .author-hero-inner :global(.breadcrumb a),
  .author-hero-inner :global(.breadcrumb span) {
    color: rgba(255,255,255,0.5);
  }
  .author-hero-inner :global(.breadcrumb a:hover) {
    color: rgba(255,255,255,0.8);
  }
  .hero-eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-warm-gold);
    margin-bottom: 24px;
    opacity: 0;
    animation: heroUp 1s cubic-bezier(0.16,1,0.3,1) forwards 0.2s;
  }
  .author-avatar-wrap {
    margin-bottom: 24px;
    opacity: 0;
    animation: heroUp 1s cubic-bezier(0.16,1,0.3,1) forwards 0.3s;
  }
  .author-avatar-large {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    margin: 0 auto;
    border: 4px solid rgba(255,255,255,0.15);
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .author-hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    color: white;
    line-height: 1.1;
    margin-bottom: 8px;
    opacity: 0;
    animation: heroUp 1s cubic-bezier(0.16,1,0.3,1) forwards 0.4s;
  }
  .hero-role {
    font-size: 1.05rem;
    color: var(--color-warm-gold);
    font-weight: 600;
    margin-bottom: 4px;
    opacity: 0;
    animation: heroUp 1s cubic-bezier(0.16,1,0.3,1) forwards 0.5s;
  }
  .hero-location {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    margin-bottom: 32px;
    opacity: 0;
    animation: heroUp 1s cubic-bezier(0.16,1,0.3,1) forwards 0.55s;
  }
  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 40px;
    opacity: 0;
    animation: heroUp 1s cubic-bezier(0.16,1,0.3,1) forwards 0.65s;
  }
  .hero-stat { text-align: center; }
  .hero-stat-num {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    color: white;
  }
  .hero-stat-label {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.45);
    font-weight: 400;
    margin-top: 2px;
  }
  @keyframes heroUp {
    from { opacity: 0; transform: translateY(28px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .section-eyebrow {
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-warm-coral);
    margin-bottom: 12px;
  }
  .section-title {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    color: var(--color-deep-night);
    line-height: 1.15;
    margin-bottom: 32px;
  }

  .bio-section {
    padding: 80px 24px 64px;
    max-width: var(--content-lg);
    margin: 0 auto;
  }
  .bio-inner { max-width: 720px; }
  .bio-content p {
    font-size: 1.02rem;
    line-height: 2;
    color: var(--color-deep-night);
    font-weight: 300;
    margin-bottom: 20px;
  }
  .bio-content strong { font-weight: 600; }

  .credentials-section {
    padding: 64px 24px 80px;
    background: var(--color-white);
  }
  .credentials-inner {
    max-width: var(--content-lg);
    margin: 0 auto;
  }
  .credential-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 720px;
  }
  .credential-list li {
    padding-left: 28px;
    position: relative;
    line-height: 1.7;
    font-size: 0.95rem;
    color: var(--color-slate);
  }
  .credential-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-warm-gold), #FBBF24);
  }
  .credential-list li strong {
    color: var(--color-deep-night);
    font-weight: 600;
  }

  .coverage-section {
    padding: 80px 24px;
    background: var(--color-sand);
  }
  .coverage-inner {
    max-width: var(--max-width, 1120px);
    margin: 0 auto;
  }
  .coverage-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .coverage-card {
    background: var(--color-white);
    border-radius: 16px;
    padding: 28px 24px;
    border: 1px solid transparent;
    transition: all 0.4s cubic-bezier(0.4,0,0.2,1);
  }
  .coverage-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 24px rgba(26,35,50,0.08);
    border-color: var(--color-sand-dark);
  }
  .coverage-icon { font-size: 1.5rem; margin-bottom: 12px; }
  .coverage-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--color-deep-night);
    margin-bottom: 8px;
  }
  .coverage-desc {
    font-size: 0.82rem;
    color: var(--color-slate);
    line-height: 1.7;
    font-weight: 300;
  }

  .content-section {
    padding: 80px 24px;
    background: var(--color-white);
  }
  .content-inner {
    max-width: var(--max-width, 1120px);
    margin: 0 auto;
  }
  .content-subhead {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-warm-gold);
    margin-bottom: 16px;
  }
  .content-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 40px;
  }
  .content-grid--destinations {
    grid-template-columns: repeat(3, 1fr);
  }
  .content-card {
    display: block;
    background: var(--color-sand);
    border-radius: 12px;
    padding: 20px;
    text-decoration: none;
    color: inherit;
    border: 1px solid transparent;
    transition: all 0.4s cubic-bezier(0.4,0,0.2,1);
  }
  .content-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 4px 20px rgba(26,35,50,0.08);
    border-color: var(--color-warm-gold);
  }
  .content-card-type {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-warm-coral);
    margin-bottom: 6px;
  }
  .content-card--dest .content-card-type { color: var(--color-warm-gold); }
  .content-card-title {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    color: var(--color-deep-night);
    line-height: 1.35;
  }
  .content-all-link { text-align: center; margin-top: 8px; }
  .content-all-link a {
    font-size: 0.88rem;
    color: var(--color-warm-gold);
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .content-all-link a:hover { color: #B8935F; }

  .email-section {
    padding: 64px 24px;
    background: var(--color-sand);
  }
  .email-section-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .back-section {
    padding: 40px 24px 64px;
    background: var(--color-sand);
  }
  .back-inner {
    max-width: var(--content-lg);
    margin: 0 auto;
    text-align: center;
  }
  .back-link {
    font-size: 0.88rem;
    color: var(--color-warm-gold);
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .back-link:hover { color: #B8935F; }

  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .author-hero { padding: 120px 24px 64px; }
    .hero-stats { gap: 24px; }
    .hero-stat-num { font-size: 1.3rem; }
    .coverage-grid { grid-template-columns: 1fr; }
    .content-grid { grid-template-columns: 1fr; }
    .content-grid--destinations { grid-template-columns: 1fr 1fr; }
    .bio-section { padding: 56px 24px 48px; }
    .credentials-section { padding: 48px 24px 56px; }
    .coverage-section { padding: 56px 24px; }
    .content-section { padding: 56px 24px; }
  }
</style>
