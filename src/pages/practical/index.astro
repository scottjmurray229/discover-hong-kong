---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import FAQ from '../../components/FAQ.astro';
import GearRecommendations from '../../components/GearRecommendations.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Travel Tips', url: '/practical/' },
];

const pageTitle = 'Hong Kong Travel Tips — Octopus Card, Money, Transport & Safety Guide 2026';
const pageDescription = 'Everything you need before your first (or tenth) trip to Hong Kong — entry requirements, Octopus card, ATMs, MTR, hiking, safety, packing, and cultural etiquette.';

interface TopicSection {
  id: string;
  icon: string;
  title: string;
  gradient: string;
  video?: string;
  items: { label: string; text: string }[];
}

const topics: TopicSection[] = [
  {
    id: 'visa',
    icon: '🛂',
    title: 'Entry Requirements',
    gradient: 'linear-gradient(135deg, #1565C0 0%, #42A5F5 100%)',
    video: '/videos/pillar/practical-break-visa.mp4',
    items: [
      { label: 'Visa-Free Entry', text: 'Citizens of most Western countries (USA, UK, Canada, Australia, EU, Japan, South Korea and 170+ others) can enter Hong Kong visa-free for 90 days. No advance application needed — just a valid passport with at least 6 months validity and a return or onward ticket.' },
      { label: 'Getting Through Immigration', text: 'Hong Kong immigration is fast and efficient. Use the e-Channel kiosks if your passport country is eligible (USA, UK, Canada, Australia, most EU countries). Hong Kong residents queue separately — tourist lines move quickly. Have your hotel address ready to write on the arrival card.' },
      { label: 'Documents to Carry', text: 'Keep your passport in your hotel safe when exploring — carry a photo of the ID page on your phone instead. Hotels require your passport at check-in, then it stays locked up. For day trips to Macau or Shenzhen, you\'ll need it at the border crossing.' },
      { label: 'Arrival at Chek Lap Kok (HKG)', text: 'Hong Kong International Airport is on Lantau Island. The Airport Express train reaches Hong Kong Station (Central) in 24 minutes for HKD 115 ($15 USD) — the fastest option by far. Taxis to Kowloon cost HKD 300–400; to Hong Kong Island HKD 350–450. Buy your Octopus card at the Airport Express counter before you do anything else.' },
      { label: 'Entry via Land Borders', text: 'You can cross into Hong Kong from mainland China at Lo Wu/Lok Ma Chau (from Shenzhen by MTR) or from Macau by ferry. Your passport is required at all border crossings. The Shenzhen crossing is efficient but busy — avoid peak hours (8–10am and 6–8pm weekdays).' },
    ],
  },
  {
    id: 'money',
    icon: '💰',
    title: 'Money & ATMs',
    gradient: 'linear-gradient(135deg, #2E7D32 0%, #66BB6A 100%)',
    video: '/videos/pillar/practical-break-money.mp4',
    items: [
      { label: 'Octopus Card — The Essential', text: 'Buy an Octopus card at the airport before you do anything else. It works on every MTR line, all buses, Star Ferry, trams, and most convenience stores. Load HKD 300 to start. Top up at any MTR station, 7-Eleven, or Circle K. It\'s far faster than paying cash for every ride.' },
      { label: 'ATM Strategy', text: 'HSBC and Hang Seng ATMs charge no fees for most international Visa/Mastercard debit cards. Avoid non-bank ATMs at convenience stores — they add HKD 20–50 per withdrawal. Withdraw in larger amounts (HKD 2,000–3,000) to minimize fees. I use a Fidelity Cash Management card exclusively — it reimburses all ATM fees.' },
      { label: 'Cash vs. Cards', text: 'Most hotels, restaurants, and shops accept Visa/Mastercard. Traditional dim sum teahouses in Jordan and Mong Kok, wet market vendors, street food stalls, and the Star Ferry are cash-only. Carry HKD 500–1,000 in cash at all times for the cash-only spots.' },
      { label: 'Daily Budget Ranges', text: 'Budget: HKD 400–600/day ($50–77 USD) — guesthouses, cha chaan teng meals, MTR. Mid-range: HKD 1,000–2,000/day ($130–260 USD) — hotels, restaurant meals, a few paid attractions. Luxury: HKD 3,000+/day ($385+ USD) — five-star hotels, harbour-view restaurants, private tours.' },
      { label: 'Currency Exchange', text: 'The Hong Kong Dollar (HKD) is pegged to the USD at approximately 7.78–7.82. Airport money changers have slightly worse rates — use an ATM on arrival instead. Licensed money changers in Tsim Sha Tsui (Nathan Road) often have competitive rates for large amounts.' },
      { label: 'Split Your Cards', text: 'Always bring at least two ATM/credit cards. Keep one locked in the hotel safe. If you lose your only card in a city of 7 million people, your trip becomes very stressful, very quickly. We learned this the hard way.' },
    ],
  },
  {
    id: 'transport',
    icon: '🚇',
    title: 'Getting Around',
    gradient: 'linear-gradient(135deg, #E65100 0%, #FF9800 100%)',
    video: '/videos/pillar/practical-break-transport.mp4',
    items: [
      { label: 'MTR — The Backbone', text: 'The MTR is one of the most efficient metro systems in the world. Punctual, clean, air-conditioned, and covers every major district. Fares range from HKD 4–50 ($0.50–6 USD) depending on distance. Download the MTR Mobile app for route planning. Your Octopus card handles every fare — no need to buy individual tickets.' },
      { label: 'Buses', text: 'Double-decker buses cover areas the MTR doesn\'t reach — the Peak, Stanley, Sai Kung, and most of the New Territories. Fares from HKD 3.40 upward. Pay by Octopus card. Bus routes are well-organized but can be slow in traffic — use them for the views, use the MTR for speed.' },
      { label: 'Star Ferry', text: 'The Star Ferry between Tsim Sha Tsui and Central/Wan Chai is an HKD 3.40 ($0.44 USD) harbour crossing with one of the best views in Asia. Take it at least once — ideally at dusk when the harbour lights come on. Upper deck for the view; lower deck is covered but cheaper.' },
      { label: 'Trams (Ding Ding)', text: 'The iconic double-decker trams run east-west along Hong Kong Island\'s northern shore from Kennedy Town to Shau Kei Wan. Flat fare HKD 3 by Octopus card. Slow but excellent for sightseeing. Take the tram along Hennessy Road through Wan Chai for pure Hong Kong atmosphere.' },
      { label: 'Taxis', text: 'Red taxis cover urban areas (HKD 28 flag fall). Green taxis serve the New Territories. Blue taxis are Lantau Island only. All use meters — no haggling. Grab works in Hong Kong and is useful for booking ahead or if you can\'t flag a cab.' },
      { label: 'Ferries to Outlying Islands', text: 'Ferry piers at Central (Pier 3–6) serve Lantau, Lamma, Cheung Chau, and Peng Chau. Round trips cost HKD 22–70 depending on the island and ferry type. Check schedules at Discover Ferry (discoverhongkong.com). The Lamma and Cheung Chau ferries run regularly — no booking needed. Pay by Octopus card at the pier.' },
    ],
  },
  {
    id: 'connectivity',
    icon: '📱',
    title: 'SIM Cards & Connectivity',
    gradient: 'linear-gradient(135deg, #6A1B9A 0%, #AB47BC 100%)',
    video: '/videos/pillar/practical-break-connectivity.mp4',
    items: [
      { label: 'You Probably Don\'t Need a Local SIM', text: 'Most US carriers include Hong Kong in their international plans — T-Mobile, Google Fi, and AT&T International Day Pass all work. Calls are typically $0.20–0.25/minute. Install WhatsApp before your trip — it\'s the primary messaging app and how hotels, guides, and restaurants communicate.' },
      { label: 'Tourist SIMs', text: 'If your carrier doesn\'t cover Hong Kong, buy a tourist SIM at the airport or any 7-Eleven. China Mobile, SmarTone, and 3 HK all sell tourist SIMs with data-only plans for HKD 48–128 ($6–16 USD) for 7–30 days. eSIM options are available through Airalo or Klook before you travel.' },
      { label: 'Data Coverage', text: 'Hong Kong has near-perfect 4G/5G coverage across all urban areas. Even on hiking trails and the outlying islands, coverage is surprisingly solid. The MTR has full mobile coverage underground. You\'ll rarely lose signal anywhere in Hong Kong.' },
      { label: 'WiFi Reliability', text: 'Hotel WiFi is generally fast (50–200 Mbps). Many MTR stations, cafes, and restaurants offer free WiFi. The City Free WiFi network covers parks, government buildings, and public spaces. You\'ll rarely need your mobile data indoors.' },
    ],
  },
  {
    id: 'safety',
    icon: '🏥',
    title: 'Safety & Health',
    gradient: 'linear-gradient(135deg, #C62828 0%, #EF5350 100%)',
    video: '/videos/pillar/practical-break-safety.mp4',
    items: [
      { label: 'Travel Insurance', text: 'Get a policy that covers medical expenses — Hong Kong has excellent private hospitals but they\'re expensive without insurance. We use <a href="https://safetywing.com/?referenceID=24858745&utm_source=24858745&utm_medium=Ambassador" target="_blank" rel="noopener sponsored">SafetyWing</a> for every trip — affordable, covers nomads and short-trippers, and you can sign up after you\'ve left home. Queen Mary Hospital and Prince of Wales are the top public hospitals; Canossa and Adventist are excellent private options.' },
      { label: 'Tap Water', text: 'Hong Kong tap water is safe to drink — one of the few cities in Asia where this is true. Bring a reusable bottle and fill up at MTR stations, hotels, and restaurants. You don\'t need to buy bottled water.' },
      { label: 'Air Conditioning Warning', text: 'Hong Kong\'s air conditioning is set to sub-zero everywhere — malls, restaurants, the MTR, cinemas. Even in 35°C heat outside, you\'ll need a light jacket the moment you step inside. This is year-round, not seasonal. Always have a layer in your bag.' },
      { label: 'Typhoon Season', text: 'June through September is typhoon season. When a Typhoon Signal 8 or above is hoisted, all businesses must close. Monitor the Hong Kong Observatory (hko.gov.hk) for updates. If you\'re there during a T8 signal, stay in your hotel. It\'s a significant weather event.' },
      { label: 'Heat & Humidity', text: 'April through October is hot and humid (28–35°C, 80–95% humidity). Hydrate constantly. The contrast between outdoor heat and indoor AC is extreme — dressing in light layers helps your body manage the temperature swings.' },
      { label: 'General Safety', text: 'Hong Kong is one of the safest cities in the world for tourists. Violent crime against tourists is essentially zero. Petty theft is rare but carry your phone in a front pocket in Mong Kok night markets. Keep valuables in your hotel safe. Emergency: dial 999.' },
    ],
  },
  {
    id: 'packing',
    icon: '🎒',
    title: 'Packing Essentials',
    gradient: 'linear-gradient(135deg, #78350F 0%, #D97706 100%)',
    video: '/videos/pillar/practical-break-packing.mp4',
    items: [
      { label: '📋 Interactive Packing Checklist', text: 'Before reading our gear picks, use our <a href="/packing-list/">interactive Hong Kong packing list</a> — 60+ items you can check off as you pack, filtered by season and activities. It\'s the fastest way to make sure nothing gets left behind.' },
      { label: 'Type G Power Adapter', text: 'Hong Kong uses Type G plugs (same as UK — 3-pin square) at 220V/50Hz. US plugs will not fit without an adapter. Buy one before you leave home — airport adapters in Hong Kong are overpriced. Most modern electronics (phones, laptops, cameras) are dual-voltage and work fine with just an adapter. Hair dryers and curling irons with a single voltage will fry.' },
      { label: 'Light Jacket — Non-Negotiable', text: 'The air conditioning in every mall, MTR station, restaurant, and cinema is set to near-freezing year-round. Even in August when it\'s 35°C outside, you\'ll need a layer within 30 seconds of walking indoors. A packable down jacket or light fleece is essential regardless of season.' },
      { label: 'Walking Shoes', text: 'Hong Kong averages 10–15km of walking per day across hills, escalators, and market streets. Get your footwear right before the trip — not after your feet are already destroyed on Day 2. If hiking Dragon\'s Back or MacLehose Trail, bring proper trail runners or hiking shoes.' },
      { label: 'Daypack (20L)', text: 'A full Hong Kong day — dim sum, hiking, ferry, night market — means carrying water, layers, and purchases. A packable 20L daypack handles everything. Use <a href="https://www.amazon.com/dp/B014VBI5MS?tag=discoverphili-20" target="_blank" rel="nofollow sponsored">packing cubes</a> to keep it organized.' },
      { label: 'Reusable Water Bottle', text: 'Hong Kong tap water is safe to drink. Bring an insulated bottle and refill at MTR stations, hotels, and restaurants. Saves money, reduces plastic, and keeps water cold against the heat. Most MTR stations have water refill stations on the platform level.' },
      { label: 'Sunscreen', text: 'The subtropical sun from April to October is intense. Bring SPF 50+ from home — sunscreen in Hong Kong pharmacies and convenience stores is available but pricier than home prices.' },
      { label: 'First Aid Basics', text: 'Pack blister plasters (10–15km/day is blister territory), pain relievers, and any prescription medications. Hong Kong pharmacies (Watson\'s, Mannings) are everywhere and well-stocked, but bring enough of your own medications for the entire trip plus a few days extra.' },
      { label: 'GaN Charger', text: 'One <a href="https://www.amazon.com/dp/B09C5RG6KV?tag=discoverphili-20" target="_blank" rel="nofollow sponsored">Anker 735 GaN 65W charger</a> with a Type G adapter replaces all your charging cables in one plug. Dual-voltage so it handles Hong Kong\'s 220V without issues.' },
    ],
  },
  {
    id: 'culture',
    icon: '🏮',
    title: 'Language & Cultural Etiquette',
    gradient: 'linear-gradient(135deg, #0D7377 0%, #14B8A6 100%)',
    video: '/videos/pillar/practical-break-culture.mp4',
    items: [
      { label: 'Basic Cantonese Phrases', text: '"M goi" (excuse me / thank you for a service), "Do je" (thank you for a gift), "Gei do cheen?" (how much?), "唔該" — even attempting a few words earns immediate goodwill. Google Translate works well — download the Cantonese offline pack before you arrive.' },
      { label: 'MTR Etiquette', text: 'Stand to the right on escalators (left side passes). Queue in the marked spots on the platform. Do not eat or drink on the MTR — fines are real. Give up seats marked for elderly/pregnant/disabled passengers. The MTR is the one place where Hong Kong\'s famous efficiency and order is most visible — respect it.' },
      { label: 'Tipping Norms', text: 'Most restaurants add a 10% service charge — check your bill. If no service charge, 10% is appropriate. Round up taxi fares. No tipping expected at cha chaan tengs, street food, or fast casual restaurants. Tipping in yum cha teahouses is not traditional but not offensive.' },
      { label: 'Temple & Religious Sites', text: 'Cover shoulders and avoid shorts at Man Mo Temple, Wong Tai Sin, and other active temples. Don\'t block the incense ceremony. Photography is usually allowed outside the main altar — use judgment and follow local lead.' },
      { label: 'Queuing', text: 'Hong Kong has an exceptionally strong queuing culture. Whether it\'s for dim sum, the Star Ferry, a taxi stand, or a ramen shop — queue properly. Cutting in line is considered extremely rude and will earn you visible disapproval from everyone around you.' },
      { label: 'Chopstick Etiquette', text: 'Don\'t stick chopsticks upright in rice (funeral symbolism). Don\'t pass food chopstick-to-chopstick (also funeral symbolism). Use the serving end to take food from shared plates. If no serving utensils, flip your chopsticks to use the handle end. These basics apply across Cantonese dining culture.' },
    ],
  },
];
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  pageType="destination"
  schemaData={{ title: pageTitle, description: pageDescription }}
  breadcrumbs={breadcrumbs}
>
  <!-- Hero -->
  <header class="prac-hero">
    <video class="prac-hero-video" autoplay muted loop playsinline preload="metadata">
      <source src="/videos/pillar/practical-hero.mp4" type="video/mp4" />
    </video>
    <div class="prac-hero-gradient"></div>
    <div class="prac-hero-noise"></div>
    <div class="prac-hero-content">
      <h1 class="prac-hero-title">Hong Kong Travel Essentials</h1>
      <p class="prac-hero-subtitle">Entry requirements, Octopus card setup, MTR guide, money strategy, safety tips, packing lists, and the cultural etiquette that turns a good trip into a great one.</p>
      <div class="prac-hero-meta">
        <div class="prac-hero-meta-item">
          <span class="prac-hero-meta-label">Topics</span>
          <span class="prac-hero-meta-value">6</span>
        </div>
        <div class="prac-hero-meta-item">
          <span class="prac-hero-meta-label">Updated</span>
          <span class="prac-hero-meta-value">Mar 2026</span>
        </div>
        <div class="prac-hero-meta-item">
          <span class="prac-hero-meta-label">Trips</span>
          <span class="prac-hero-meta-value">10+</span>
        </div>
      </div>
    </div>
    <div class="prac-scroll-hint">Scroll<br />&#8595;</div>
  </header>

  <!-- Breadcrumb -->
  <div class="container-content">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- Personal intro -->
  <section class="prac-personal reveal">
    <div class="container-content">
      <blockquote class="prac-personal-quote">
        <p>We've made every mistake in this guide at least once — from forgetting the Type G adapter to wearing the wrong shoes for the hills of Sheung Wan. After 10+ trips together, Jenice and I have figured out the practical side of Hong Kong travel so you don't have to learn the hard way. This is the cheat sheet we wish someone had handed us in 2007.</p>
        <cite>— Scott &amp; Jenice</cite>
      </blockquote>
    </div>
  </section>

  <!-- Quick Nav -->
  <section class="prac-quicknav reveal">
    <div class="container-content">
      <div class="prac-quicknav-grid">
        {topics.map((t) => (
          <a href={`#${t.id}`} class="prac-quicknav-chip">
            <span class="prac-quicknav-icon">{t.icon}</span>
            <span class="prac-quicknav-label">{t.title.split(' ').slice(0, 2).join(' ')}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Topic Sections -->
  {topics.map((topic) => (
    <section class="prac-topic reveal" id={topic.id}>
      <div class="container-content">
        <div class="prac-topic-header" style={`background: ${topic.gradient};`}>
          {topic.video && (
            <video class="prac-topic-video" autoplay muted loop playsinline preload="none">
              <source src={topic.video} type="video/mp4" />
            </video>
          )}
          <div class="prac-topic-header-inner">
            <span class="prac-topic-icon">{topic.icon}</span>
            <h2 class="prac-topic-title">{topic.title}</h2>
            <span class="prac-topic-count">{topic.items.length} tips</span>
          </div>
        </div>

        <div class="prac-tip-grid">
          {topic.items.map((item) => (
            <div class="prac-tip-card">
              <h3 class="prac-tip-label">{item.label}</h3>
              <p class="prac-tip-text" set:html={item.text} />
            </div>
          ))}
        </div>

        {topic.id === 'transport' && (
          <div class="prac-transport-widget">
            <h3 class="prac-transport-widget-title">Search Routes & Book Transport</h3>
            <p class="prac-transport-widget-desc">Compare transport options in and around Hong Kong.</p>
            <div class="prac-transport-widget-inner">
              <script src="//cdn0.trainbusferry.com/tools/form/en/?id=15062413&domain=12go.asia" data-one2go="15062413" data-color="blue" data-language="en" data-width="250" data-height="320" data-border="1" data-radius="8" data-caption="Find Transport in Hong Kong" data-sub_id="discoveringhongkong" data-domain="12go.asia"></script>
            </div>
            <div class="prac-transport-widget-powered">Powered by <a href="https://12go.asia/?z=15062413&sub_id=discoveringhongkong" target="_blank" rel="noopener sponsored">12Go Asia</a></div>
          </div>
        )}
      </div>
    </section>
  ))}

  <!-- Affiliate Disclosure -->
  <div class="container-content reveal" style="padding-bottom: 0;">
    <p class="prac-affiliate-disclosure">Some links on this page are affiliate links — we earn a small commission if you purchase through them, at no extra cost to you. We only recommend gear we personally use on our Hong Kong trips. <a href="/legal/affiliate-disclosure/">Full disclosure</a>.</p>
  </div>

  <!-- Bottom CTA -->

  <section class="prac-gear-section reveal">
    <div class="container-content">
      <h2 class="prac-gear-heading">Gear We Recommend</h2>
      <GearRecommendations />
    </div>
  </section>
  <section class="prac-cta-section reveal">
    <div class="container-content">
      <div class="prac-cta-card">
        <h2 class="prac-cta-heading">Plan Your Hong Kong Trip</h2>
        <p class="prac-cta-text">Tell our AI planner your dates, budget, and interests — it builds a custom day-by-day itinerary with transport, hotels, and activities in HKD.</p>
        <a href="/plan/" class="prac-cta-button">Start Planning &rarr;</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ items={[
    { question: "Do I need a visa to visit Hong Kong?", answer: "Most Western nationalities (USA, UK, Canada, Australia, EU, Japan, South Korea) can visit Hong Kong visa-free for 90 days. No advance application needed — just a valid passport with at least 6 months validity and a return or onward ticket. Present this at immigration on arrival at Chek Lap Kok airport." },
    { question: "Is Hong Kong safe for tourists?", answer: "Hong Kong is one of the safest cities in the world for tourists. Violent crime against visitors is essentially zero. Petty theft is rare but keep your phone in a front pocket in crowded night markets. Emergency number is 999. The MTR, taxis, and licensed vehicles are all safe to use." },
    { question: "How much money should I bring to Hong Kong?", answer: "Budget travelers: HKD 400–600/day ($50–77 USD) covers guesthouses, cha chaan teng meals, and the MTR. Mid-range: HKD 1,000–2,000/day ($130–260 USD) for hotels and restaurant meals. Luxury: HKD 3,000+/day ($385+ USD) for five-star hotels and harbour-view dining. Withdraw HKD from HSBC or Hang Seng ATMs on arrival." },
    { question: "What is the best way to get around Hong Kong?", answer: "The MTR is the fastest and most efficient option for inter-district travel. Buy an Octopus card at the airport — it works on all MTR lines, buses, trams, Star Ferry, and most convenience stores. The Star Ferry (HKD 3.40) crosses the harbour between Tsim Sha Tsui and Central. Taxis are metered and reliable — red taxis cover urban areas." },
    { question: "What power adapter do I need for Hong Kong?", answer: "Hong Kong uses Type G plugs (3-pin square, same as UK) at 220V/50Hz. US plugs will not fit. Buy a Type G adapter before you leave home — airport versions are overpriced. Most modern electronics (phones, laptops, cameras) are dual-voltage and work fine with just an adapter. Hair dryers and appliances with a single voltage rating will be damaged." },
    { question: "Do I need a SIM card for Hong Kong?", answer: "Most US carriers (T-Mobile, Google Fi, AT&T International Day Pass) include Hong Kong coverage. If yours doesn't, buy a tourist SIM at the airport for HKD 48–128 ($6–16 USD) from China Mobile, SmarTone, or 3 HK. Alternatively, set up an eSIM through Airalo or Klook before you travel. Hong Kong has excellent 4G/5G coverage everywhere including the MTR underground." },
  ]} />

  <!-- Email Capture -->
  <div class="container-content reveal" style="padding-bottom: var(--space-6);">
    <EmailCapture
      leadMagnet="Get Our Free Hong Kong Travel Essentials Guide"
      description="A printable PDF covering everything in this guide — plus MTR map, emergency contacts, and a packing checklist."
      bullets={[
        'Octopus card setup guide and top-up locations',
        'ATM strategy and daily budget planner in HKD & USD',
        'Printable Cantonese phrase card for markets and dining',
        'Packing checklist with hiking and urban variants',
      ]}
      guideTag="pillar-practical"
    />
  </div>

  <!-- Cross-links -->
  <section class="prac-crosslinks reveal">
    <div class="container-content">
      <h3 class="prac-crosslinks-heading">Explore More</h3>
      <div class="prac-crosslinks-grid">
        <a href="/hiking-hong-kong/" class="prac-crosslink-card">
          <span class="prac-crosslink-icon">&#127956;</span>
          <span class="prac-crosslink-label">Hiking Guide</span>
          <span class="prac-crosslink-desc">Dragon's Back, MacLehose Trail, and 200+ trails ranked</span>
        </a>
        <a href="/festivals/" class="prac-crosslink-card">
          <span class="prac-crosslink-icon">&#127914;</span>
          <span class="prac-crosslink-label">Festival Calendar</span>
          <span class="prac-crosslink-desc">Hong Kong festivals month by month with what to expect</span>
        </a>
        <a href="/cuisine/" class="prac-crosslink-card">
          <span class="prac-crosslink-icon">&#127860;</span>
          <span class="prac-crosslink-label">Food & Cuisine</span>
          <span class="prac-crosslink-desc">Dim sum, roast goose, wonton noodles, and more</span>
        </a>
        <a href="/dim-sum-guide/" class="prac-crosslink-card">
          <span class="prac-crosslink-icon">&#129348;</span>
          <span class="prac-crosslink-label">Dim Sum Guide</span>
          <span class="prac-crosslink-desc">The teahouses, the menu, and how to order like a local</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- Scroll Reveal Observer -->
<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));
  } else {
    document.querySelectorAll('.reveal').forEach((el) => el.classList.add('visible'));
  }
</script>

<style>
  /* ================================================================
     HERO — Practical travel gradient (no video)
     ================================================================ */
  .prac-hero {
    position: relative;
    min-height: 55vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 5rem var(--space-6) 60px;
    overflow: hidden;
  }

  .prac-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .prac-hero-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
