---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import FAQ from '../../components/FAQ.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Hong Kong Food Guide', url: '/cuisine/' },
];

const pageTitle = 'Hong Kong Food Guide — Dim Sum, Roast Goose, Street Food & More';
const pageDescription = 'A neighbourhood-by-neighbourhood guide to the dishes that define Hong Kong food culture — from Jordan teahouse dim sum to Sham Shui Po street food to Sai Kung seafood.';

interface Dish {
  name: string;
  image?: string;
  destination: string;
  slug: string;
  price: string;
  description: string;
  tag?: string;
}

interface MenuSection {
  region: string;
  tagline: string;
  gradient: string;
  dishes: Dish[];
}

const menu: MenuSection[] = [
  {
    region: 'Dim Sum & Yum Cha',
    tagline: 'The heart of Cantonese food culture — teahouse dining at its finest',
    gradient: 'linear-gradient(135deg, #BF360C 0%, #E8654A 100%)',
    dishes: [
      {
        name: 'Har Gow (Shrimp Dumplings)',
        destination: 'Jordan / Mong Kok',
        slug: 'jordan',
        price: 'HKD 42-65 / $5-8 USD',
        description: 'The benchmark dish for any dim sum restaurant. Translucent pleated wrappers, plump whole shrimp. A master chef har gow wrapper is thin enough to be nearly transparent. Order these first at any teahouse.',
        tag: 'Essential',
      },
      {
        name: 'Siu Mai (Pork & Shrimp Dumplings)',
        destination: 'Jordan / Mong Kok',
        slug: 'mong-kok',
        price: 'HKD 38-60 / $5-8 USD',
        description: 'Open-topped steamed dumplings filled with pork and shrimp, topped with a dot of roe or carrot. The most popular dim sum item in Hong Kong. Available at every teahouse.',
        tag: 'Must-Try',
      },
      {
        name: 'Cheung Fun (Rice Noodle Rolls)',
        destination: 'Yau Ma Tei / Jordan',
        slug: 'jordan',
        price: 'HKD 35-55 / $4.50-7 USD',
        description: 'Silky steamed rice noodle sheets rolled around shrimp, char siu pork, or beef. Served with sweet soy, sesame sauce, and peanut sauce. The texture is what Hong Kong street food is famous for.',
        tag: 'Local Favourite',
      },
      {
        name: 'Dan Tart (Egg Tart)',
        destination: 'Citywide',
        slug: 'central',
        price: 'HKD 8-18 / $1-2.30 USD each',
        description: 'The definitive Hong Kong pastry. A buttery shortcrust shell filled with smooth, lightly sweet baked egg custard. Eat warm from a bakery. Tai Cheong Bakery in Central is the famous version.',
        tag: 'Icon',
      },
      {
        name: 'Lo Mai Gai (Sticky Rice in Lotus Leaf)',
        destination: 'Citywide',
        slug: 'tsim-sha-tsui',
        price: 'HKD 45-70 / $6-9 USD each',
        description: 'Glutinous rice packed with chicken, mushrooms, Chinese sausage, and egg yolk, wrapped in lotus leaf and steamed until fragrant. Heavy and filling — order one per two people.',
      },
      {
        name: 'Char Siu Bao (BBQ Pork Bun)',
        destination: 'Citywide',
        slug: 'central',
        price: 'HKD 20-40 / $2.50-5 USD each',
        description: 'Available steamed (soft, pillowy) or baked (glazed, golden). Both are Cantonese icons. The baked version from cha chaan tengs is a perfect breakfast. The steamed version is a dim sum staple.',
      },
    ],
  },
  {
    region: 'Roast Meats & Noodles',
    tagline: 'Cantonese roasting traditions and the wonton noodles worth waking up early for',
    gradient: 'linear-gradient(135deg, #78350F 0%, #B45309 100%)',
    dishes: [
      {
        name: 'Roast Goose',
        destination: 'Wan Chai / Central',
        slug: 'wan-chai',
        price: 'HKD 80-150 / $10-19 USD (half portion)',
        description: "The pinnacle of Cantonese roast cooking. Crispy mahogany skin, rich dark meat, rendered fat. Kam's Roast Goose in Wan Chai has the queue of locals that means something. Order with rice and mustard.",
        tag: 'Must-Try',
      },
      {
        name: 'Char Siu (BBQ Pork)',
        destination: 'Citywide',
        slug: 'mong-kok',
        price: 'HKD 60-100 / $8-13 USD (portion)',
        description: 'Pork neck marinated in honey, five-spice, and red yeast rice, roasted until caramelized. The fatty cuts are best. Eat with white rice and the pan drippings.',
        tag: 'Essential',
      },
      {
        name: 'Wonton Noodles',
        destination: 'Jordan / Sham Shui Po',
        slug: 'jordan',
        price: 'HKD 35-65 / $4.50-8 USD',
        description: 'Thin, springy egg noodles in clear shrimp roe broth, with three or four wontons. The broth takes hours. The noodles are cooked in seconds. Best bowls found in no-English-menu shops.',
        tag: 'Icon',
      },
      {
        name: 'Curry Fish Balls',
        destination: 'Citywide Street Food',
        slug: 'mong-kok',
        price: 'HKD 15-25 / $2-3 USD (portion)',
        description: 'The definitive Hong Kong street food. Spongy fish balls in thick, mildly spicy curry sauce on skewers. Available throughout Mong Kok, Sham Shui Po, and Temple Street Night Market.',
        tag: 'Street Food',
      },
      {
        name: 'Congee (Rice Porridge)',
        destination: 'Citywide',
        slug: 'tsim-sha-tsui',
        price: 'HKD 30-70 / $4-9 USD',
        description: 'Slow-cooked rice porridge with toppings: century egg and pork, fish, abalone, or preserved vegetable. A Hong Kong breakfast institution available at shops opening at 6am.',
      },
      {
        name: 'Pineapple Bun (Bo Lo Bao)',
        destination: 'Cha Chaan Tengs Citywide',
        slug: 'central',
        price: 'HKD 12-22 / $1.50-3 USD',
        description: 'Soft milk bread with a crumbly sweet pastry crust — no actual pineapple. The Hong Kong upgrade: order with a thick slab of butter inside (bo lo yau). A cha chaan teng breakfast staple.',
        tag: 'Local Favourite',
      },
    ],
  },
  {
    region: 'Seafood & Outlying Islands',
    tagline: 'Fresh seafood from Sai Kung, Lamma, and Tai O',
    gradient: 'linear-gradient(135deg, #065F46 0%, #059669 100%)',
    dishes: [
      {
        name: 'Sai Kung Seafood',
        destination: 'Sai Kung',
        slug: 'sai-kung',
        price: 'HKD 150-400 / $19-51 USD (per dish)',
        description: 'Choose live seafood from waterfront tanks: coral trout, mantis shrimp, crab. The restaurant steams it with ginger and scallion. Priced by weight, agree before cooking.',
        tag: 'Must-Try',
      },
      {
        name: 'Lamma Island Seafood',
        destination: 'Lamma Island',
        slug: 'lamma-island',
        price: 'HKD 120-300 / $15-38 USD (per dish)',
        description: "A 25-minute ferry from Central. Sok Kwu Wan and Yung Shue Wan have waterfront seafood restaurants. Cheaper and more relaxed than Sai Kung. The whole steamed fish and garlic butter crab are the standards.",
      },
      {
        name: 'Tai O Dried Seafood & Shrimp Paste',
        destination: 'Tai O, Lantau',
        slug: 'tai-o',
        price: 'HKD 20-80 / $2.50-10 USD',
        description: 'The stilt village of Tai O is famous for dried seafood and shrimp paste. The flavour is intense. Buy small jars to take home. Try the fish balls at the market stalls.',
        tag: 'Local Speciality',
      },
    ],
  },
  {
    region: 'Cha Chaan Teng Culture',
    tagline: 'Hong Kong milk tea, pineapple buns, and the diner culture that defines the city',
    gradient: 'linear-gradient(135deg, #1a1035 0%, #4C1D95 100%)',
    dishes: [
      {
        name: 'Hong Kong Milk Tea',
        destination: 'Cha Chaan Tengs Citywide',
        slug: 'central',
        price: 'HKD 18-35 / $2.30-4.50 USD',
        description: 'Strong Ceylon tea blended with evaporated milk, filtered through a cloth sock. Stronger and richer than British-style milk tea. Served hot or iced. The standard by which every cha chaan teng is judged.',
        tag: 'Icon',
      },
      {
        name: 'Yuenyeung (Coffee-Tea Mix)',
        destination: 'Cha Chaan Tengs Citywide',
        slug: 'mong-kok',
        price: 'HKD 20-38 / $2.50-5 USD',
        description: 'A Hong Kong invention: three parts milk tea, one part coffee. Stronger than either alone, somehow balanced. A true cha chaan teng classic you will not find anywhere else in the world.',
        tag: 'HK Only',
      },
      {
        name: 'French Toast (Sai Do Si)',
        destination: 'Cha Chaan Tengs Citywide',
        slug: 'wan-chai',
        price: 'HKD 35-65 / $4.50-8 USD',
        description: 'Thick white bread with peanut butter or kaya jam, dipped in egg, deep-fried until golden, topped with butter and condensed milk. A Hong Kong cha chaan teng breakfast standard.',
        tag: 'Local Favourite',
      },
    ],
  },
];
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  pageType="destination"
  schemaData={{ title: pageTitle, description: pageDescription }}
  breadcrumbs={breadcrumbs}
>
  <!-- Hero -->
  <header class="menu-hero">
    <video class="menu-hero-video" autoplay muted loop playsinline preload="metadata">
      <source src="/videos/pillar/cuisine-hero.mp4" type="video/mp4" />
    </video>
    <div class="menu-hero-gradient"></div>
    <div class="menu-hero-noise"></div>
    <div class="menu-hero-content">
      <h1 class="menu-hero-title">The Hong Kong Menu</h1>
      <p class="menu-hero-subtitle">Dim sum at 6am, wonton noodles in a basement shop with no English menu, roast goose you can smell from the end of the street — eat your way across Hong Kong and discover the dishes that define Cantonese food culture.</p>
      <div class="menu-hero-meta">
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Dishes</span>
          <span class="menu-hero-meta-value">22</span>
        </div>
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Regions</span>
          <span class="menu-hero-meta-value">3</span>
        </div>
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Destinations</span>
          <span class="menu-hero-meta-value">12</span>
        </div>
      </div>
    </div>
    <div class="menu-scroll-hint">Scroll<br />&#8595;</div>
  </header>

  <!-- Breadcrumb -->
  <div class="container-content">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- Personal intro -->
  <section class="menu-personal reveal">
    <div class="container-content">
      <blockquote class="menu-personal-quote">
        <p>I knew nothing about Cantonese food before my first Hong Kong trip in 2007. I started with the obvious — wonton noodles, roast duck on rice, pineapple buns at a cha chaan teng — and fell hard. But it was Jenice who pushed me deeper: har gow at 6am in a Jordan teahouse, roast goose at Kam's that I would never have found on my own. Dishes I didn't know existed, in restaurants with no English menus. Every trip now, the food is half the reason we go.</p>
        <cite>— Scott</cite>
      </blockquote>
    </div>
  </section>

  <!-- Menu Intro -->
  <section class="menu-intro reveal">
    <div class="container-content">
      <div class="menu-intro-card">
        <p class="menu-intro-text">Think of this as your tasting menu for Hong Kong. We've organized the essential dishes by neighbourhood — <strong>dim sum</strong> in Jordan teahouses, <strong>roast meats</strong> in Wan Chai siu mei shops, <strong>seafood</strong> on Lamma and Sai Kung, and <strong>cha chaan teng culture</strong> everywhere. Click any dish to explore the neighbourhood where it's famous.</p>
        <div class="menu-intro-legend">
          <span class="menu-tag menu-tag--heritage">Heritage</span>
          <span class="menu-tag menu-tag--musttry">Must-Try</span>
          <span class="menu-tag menu-tag--iconic">Iconic</span>
          <span class="menu-tag menu-tag--fresh">Fresh Catch</span>
          <span class="menu-tag menu-tag--rare">Rare</span>
          <span class="menu-tag menu-tag--pasalubong">Pasalubong</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Menu Sections by Region -->
  {menu.map((section) => (
    <section class="menu-region reveal">
      <div class="container-content">
        <div class="menu-region-header" style={`background: ${section.gradient};`}>
          <div class="menu-region-header-inner">
            <h2 class="menu-region-name">{section.region}</h2>
            <p class="menu-region-tagline">{section.tagline}</p>
            <span class="menu-region-count">{section.dishes.length} dishes</span>
          </div>
          <div class="menu-region-ornament">&#9733;</div>
        </div>

        <div class="menu-dish-grid">
          {section.dishes.map((dish) => (
            <a href={`/destinations/${dish.slug}/`} class="menu-dish-card">
              <div class="menu-dish-media" style={`background: ${section.gradient};`}>
                {dish.image && (
                  <img src={dish.image} alt={`${dish.name} — ${dish.destination}`} class="menu-dish-img" loading="lazy" />
                )}
                {dish.tag && (
                  <span class={`menu-tag menu-tag--${dish.tag.toLowerCase().replace(/[^a-z]/g, '')}`}>{dish.tag}</span>
                )}
              </div>
              <div class="menu-dish-body">
                <div class="menu-dish-top">
                  <h3 class="menu-dish-name">{dish.name}</h3>
                  <span class="menu-dish-price">{dish.price}</span>
                </div>
                <p class="menu-dish-destination">{dish.destination}</p>
                <p class="menu-dish-desc">{dish.description}</p>
                <span class="menu-dish-cta">Explore {dish.destination} &rarr;</span>
              </div>
              <div class="menu-dish-overlay">
                <p class="menu-dish-overlay-desc">{dish.description}</p>
                <span class="menu-dish-overlay-cta">Explore {dish.destination} &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Bottom CTA -->
  <section class="menu-cta-section reveal">
    <div class="container-content">
      <div class="menu-cta-card">
        <h2 class="menu-cta-heading">Plan Your Food Trip</h2>
        <p class="menu-cta-text">Tell our AI planner which dishes you want to try and it will build a neighbourhood-by-neighbourhood itinerary — with the best teahouses, roast meat shops, and street food stops in HKD.</p>
        <a href="/plan/" class="menu-cta-button">Start Planning &rarr;</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ items={[
    { question: "What is the best dim sum in Hong Kong?", answer: "For authentic experiences, look for teahouses in Jordan and Mong Kok that open before 7am and have trolley service. Tim Ho Wan (cheapest Michelin-starred restaurant in the world) has multiple locations and is excellent value. The quality gap between tourist-oriented and local-oriented dim sum is significant." },
    { question: "How much does dim sum cost in Hong Kong?", answer: "At a local teahouse, a full dim sum breakfast for two with tea costs HKD 120-180 ($15-23 USD). At mid-range restaurants, expect HKD 200-350 per person. The best value dim sum is at the unfancy teahouses where the regulars sit, not restaurants with photos in the menu." },
    { question: "What is a cha chaan teng?", answer: "A cha chaan teng is a Hong Kong-style diner: casual, fast, cheap, and open early and late. They serve Hong Kong milk tea, pineapple buns, French toast, instant noodles, congee, and rice dishes. The decor is fluorescent lights and plastic chairs. The milk tea is usually exceptional." },
    { question: "What street food should I try in Hong Kong?", answer: "Curry fish balls, egg waffles (gai daan jai), cheung fun from street carts in Yau Ma Tei, and stinky tofu if you are brave. Temple Street Night Market has street food carts. Sham Shui Po has authentic street food that has not been gentrified for tourists." },
    { question: "Can I eat well in Hong Kong on a budget?", answer: "A bowl of wonton noodles costs HKD 35-45. A cha chaan teng set meal (milk tea plus toast plus egg) is HKD 40-65. Roast meat rice at a siu mei shop runs HKD 55-80. A full dim sum breakfast at a local teahouse costs HKD 60-90 per person. Hong Kong has some of the best cheap food in Asia." },
    { question: "Where should I eat: Tsim Sha Tsui vs Mong Kok vs Jordan?", answer: "Tsim Sha Tsui has everything but skews tourist-priced. Jordan and Yau Ma Tei have the best traditional teahouses and wonton noodle shops. Mong Kok has the best street food and night market eating. Sham Shui Po is the most local and cheapest eating district in the city." },
  ]} />

  <!-- Email Capture -->
  <div class="container-content reveal" style="padding-bottom: var(--space-6);">
    <EmailCapture
      leadMagnet="Get Our Free Hong Kong Food Guide"
      description="A neighbourhood-by-neighbourhood PDF guide to Hong Kong food — dim sum teahouses, roast meat shops, cha chaan tengs, and the dishes you cannot miss."
      bullets={[
        'All 22 dishes with where to find the best version',
        'Price guide — from HKD 35 street food to HKD 400 restaurant plates',
        'Dim sum ordering guide with Cantonese names',
        'Cha chaan teng phrase card for ordering like a local',
      ]}
      guideTag="pillar-cuisine"
    />
  </div>

  <!-- Cross-links -->
  <section class="menu-crosslinks reveal">
    <div class="container-content">
      <h3 class="menu-crosslinks-heading">Explore More</h3>
      <div class="menu-crosslinks-grid">
        <a href="/festivals/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#127914;</span>
          <span class="menu-crosslink-label">Festival Calendar</span>
          <span class="menu-crosslink-desc">Hong Kong festivals month by month with what to expect</span>
        </a>
        <a href="/hiking-hong-kong/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#127754;</span>
          <span class="menu-crosslink-label">Hiking Guide</span>
          <span class="menu-crosslink-desc">Dragon's Back, MacLehose Trail, and the best trails</span>
        </a>
        <a href="/destinations/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#127965;</span>
          <span class="menu-crosslink-label">All Destinations</span>
          <span class="menu-crosslink-desc">Every island we've explored with honest reviews</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- Scroll Reveal Observer -->
<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));
  } else {
    document.querySelectorAll('.reveal').forEach((el) => el.classList.add('visible'));
  }
</script>

<style>
  /* ================================================================
     HERO — Warm, food-inspired gradient
     ================================================================ */
  .menu-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 5rem var(--space-6) 60px;
    overflow: hidden;
  }

  .menu-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .menu-hero-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.15) 40%, rgba(0,0,0,0.55) 100%);
  }

  .menu-hero-noise {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  .menu-hero-content {
    position: relative;
    z-index: 3;
    max-width: 720px;
  }

  .menu-hero-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: var(--weight-bold);
    color: #fff;
    line-height: 1.1;
    margin: 0 0 var(--space-3);
  }

  .menu-hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    margin: 0 0 var(--space-5);
    max-width: 580px;
  }

  .menu-hero-meta {
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .menu-hero-meta-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .menu-hero-meta-label {
    font-size: 0.65rem;
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.5);
  }

  .menu-hero-meta-value {
    font-size: 1.1rem;
    font-weight: var(--weight-bold);
    color: #fff;
  }

  .menu-scroll-hint {
    position: absolute;
    bottom: 16px;
    right: var(--space-6);
    z-index: 3;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.35);
    text-align: center;
    animation: menuBounce 2s ease-in-out infinite;
  }

  @keyframes menuBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ================================================================
     MENU INTRO
     ================================================================ */
  .menu-intro {
    padding: var(--space-8) 0 var(--space-4);
  }

  .menu-intro-card {
    background: var(--color-white);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 16px;
    padding: var(--space-5) var(--space-6);
    text-align: center;
  }

  .menu-intro-text {
    font-size: 1rem;
    color: var(--color-slate);
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto var(--space-4);
  }

  .menu-intro-legend {
    display: flex;
    justify-content: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  /* ================================================================
     TAGS
     ================================================================ */
  .menu-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 8px;
    border-radius: 6px;
    line-height: 1.4;
  }

  .menu-tag--heritage {
    background: rgba(191, 54, 12, 0.1);
    color: #BF360C;
  }

  .menu-tag--musttry, .menu-tag--mustry {
    background: rgba(13, 115, 119, 0.1);
    color: var(--color-ocean-teal);
  }

  .menu-tag--iconic {
    background: rgba(212, 168, 83, 0.15);
    color: #9A7B2E;
  }

  .menu-tag--freshcatch {
    background: rgba(33, 150, 243, 0.1);
    color: #1565C0;
  }

  .menu-tag--rare {
    background: rgba(106, 27, 154, 0.1);
    color: #6A1B9A;
  }

  .menu-tag--pasalubong {
    background: rgba(232, 101, 74, 0.1);
    color: var(--color-warm-coral);
  }

  .menu-tag--legendary {
    background: rgba(212, 168, 83, 0.15);
    color: #9A7B2E;
  }

  .menu-tag--nationaldish {
    background: rgba(191, 54, 12, 0.1);
    color: #BF360C;
  }

  /* ================================================================
     REGION SECTION
     ================================================================ */
  .menu-region {
    padding: var(--space-6) 0;
  }

  .menu-region-header {
    position: relative;
    border-radius: 20px;
    padding: var(--space-6) var(--space-6);
    margin-bottom: var(--space-6);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .menu-region-header-inner {
    position: relative;
    z-index: 1;
  }

  .menu-region-name {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: var(--weight-bold);
    color: #fff;
    margin: 0 0 var(--space-1);
    line-height: 1.1;
  }

  .menu-region-tagline {
    font-size: 0.95rem;
