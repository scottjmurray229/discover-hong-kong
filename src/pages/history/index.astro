  }

  /* ================================================================
     CROSS-LINKS
     ================================================================ */
  .ww2-crosslinks {
    padding: 0 0 var(--space-10);
  }

  .ww2-crosslinks-heading {
    font-size: 1.1rem;
    font-weight: var(--weight-bold);
