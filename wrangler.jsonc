{
	"main": "dist/_worker.js/index.js",
	"name": "discover-hong-kong",
  "compatibility_date": "2026-02-04",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
    "enabled": true
  },
"d1_databases": [
    {
      "binding": "DB",
      "database_name": "trip-planner-cache-ph",
      "database_id": "a2c631d9-8e4d-4b2e-a335-e2ed55f96bfa"
    }
  ]
}